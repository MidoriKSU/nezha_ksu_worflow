From: Midori <lv@lvlv.lv>
Date: Fri, 24 Apr 2026 19:19:00 +0900
Subject: [PATCH] Fix latest SuSFS for MidoriSU/KowSU by Midori

---
 kernel/core/init.c           | 6 ++++++
 kernel/supercall/dispatch.c  | 6 ++----
 kernel/supercall/supercall.c | 2 +-
 3 files changed, 9 insertions(+), 5 deletions(-)

diff --git a/kernel/core/init.c b/kernel/core/init.c
--- a/kernel/core/init.c
+++ b/kernel/core/init.c
@@ -1,2 +1,8 @@
+#include <linux/types.h>
+#include <linux/export.h>
+bool ksu_is_init_rc_hook_enabled = false;
+EXPORT_SYMBOL(ksu_is_init_rc_hook_enabled);
+bool ksu_is_input_hook_enabled = false;
+EXPORT_SYMBOL(ksu_is_input_hook_enabled);
 #include <linux/kernel.h>
 #include <linux/sched.h>
diff --git a/kernel/supercall/dispatch.c b/kernel/supercall/dispatch.c
--- a/kernel/supercall/dispatch.c
+++ b/kernel/supercall/dispatch.c
@@ -448,10 +448,8 @@ int ksu_handle_sys_reboot(int magic1, int magic2, unsigned int cmd, void __user
         return -EINVAL;
     }
 
-    if (magic2 == KSU_INSTALL_MAGIC2)
-        return ksu_supercall_reboot_handler(arg);
-
-    return -EINVAL;
+    extern int midorisu_handle_sys_reboot(int magic1, int magic2, unsigned int cmd, void __user **arg);
+    return midorisu_handle_sys_reboot(magic1, magic2, cmd, arg);
 }
 
 static int do_nuke_ext4_sysfs(void __user *arg)
diff --git a/kernel/supercall/supercall.c b/kernel/supercall/supercall.c
--- a/kernel/supercall/supercall.c
+++ b/kernel/supercall/supercall.c
@@ -84,8 +84,8 @@ extern uint32_t ksuver_override;
 extern uint32_t ksuflags_override;
 
 // downstream: make sure to pass arg as reference, this can allow us to extend things.
-static int ksu_handle_sys_reboot(int magic1, int magic2, unsigned int cmd, void __user **arg)
+int midorisu_handle_sys_reboot(int magic1, int magic2, unsigned int cmd, void __user **arg)
 {
 
     if (magic1 != KSU_INSTALL_MAGIC1)
