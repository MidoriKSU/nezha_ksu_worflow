+    uid_t uid = current_uid().val;
+    if (uid % 100000 < 10000) return 0;
+    if (!__ksu_is_allow_uid_for_current(uid)) return 0;
+
+    if (ksu_file_sid) {
+        struct inode_security_struct *sec = selinux_inode(inode);
+        if (sec) sec->sid = ksu_file_sid;
+    }
+    return 0;
+}
